{
  "meta": {
    "run_name": "train",
    "description": "Fast training — batch=32, cosine LR, 1000 steps, TensorBoard on",
    "tags": ["fast", "tensorboard"]
  },

  "environment": {
    "device": "mps",
    "dtype": "bfloat16",
    "seed": 42,
    "num_workers": 0
  },

  "tokenizer": {
    "tok_id": "tok_bpe_8k"
  },

  "dataset": {
    "ds_id":    "ds_tinystories_tok_bpe8k_T128",
    "data_dir": "data/clean"
  },

  "model": {
    "architecture": "gpt",
    "n_layer": 4,
    "n_head": 4,
    "n_embd": 1024,
    "dropout": 0.02,
    "block_size": 128,
    "bias": false,
    "vocab_size": 8000
  },

  "training": {
    "batch_size": 4,
    "max_steps": 1000,
    "learning_rate": 0.0003,
    "scheduler": "cosine",
    "warmup_steps": 200,
    "grad_clip": 1.0,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.95,
    "eval_interval": 100,
    "eval_steps": 20,
    "checkpoint_interval": 999999,
    "checkpoint_mode": "best_and_latest"
  },

  "observability": {
    "log_interval": 100,
    "tensorboard": true,
    "tensorboard_weights": false,
    "jsonlog": false,
    "langfuse": false
  }
}
