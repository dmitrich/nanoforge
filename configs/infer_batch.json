{
  "meta": {
    "infer_name": "infer_batch",
    "description": "Batch inference with predefined prompts",
    "tags": ["batch"]
  },

  "source": {
    "run_id": null,
    "checkpoint": "best"
  },

  "model": { "$from_run": true },
  "tokenizer": { "$from_run": true },

  "generation": {
    "max_new_tokens": 200,
    "temperature": 0.8,
    "top_k": 40,
    "strategy": "top_k",
    "stop_tokens": ["</s>", "\n\n"]
  },

  "input": {
    "mode": "batch",
    "interactive": false,
    "evals": false,
    "prompts": [
      "Once upon a time",
      "The little girl",
      "In a magical forest"
    ]
  }
}
