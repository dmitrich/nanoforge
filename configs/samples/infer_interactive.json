{
  "meta": {
    "infer_name": "infer_interactive",
    "description": "Interactive inference - prompt user for input",
    "tags": ["interactive"]
  },

  "source": {
    "run_id": null,
    "checkpoint": "best"
  },

  "model": { "$from_run": true },
  "tokenizer": { "$from_run": true },

  "generation": {
    "max_new_tokens": 200,
    "temperature": 0.8,
    "top_k": 40,
    "strategy": "top_k",
    "stop_tokens": ["</s>", "\n\n"]
  },

  "input": {
    "mode": "interactive",
    "interactive": true,
    "evals": false
  }
}
